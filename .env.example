# Copy this file to .env.local and fill in the values

# Optional: serve the app at a URL sub-path (e.g. /primordia).
# Leave unset (or empty) to serve from the root (default).
# NEXT_BASE_PATH=/primordia

# Reverse proxy port — required. The public-facing port users connect to.
# The Next.js app listens on PORT (default 3001); the proxy forwards there.
REVERSE_PROXY_PORT=3000

# Optional: public-facing URL of this instance (used in /.well-known/primordia.json).
# If unset, derived automatically from the incoming request's host header.
# Required if PRIMORDIA_PARENT_URL is set (the parent needs a URL to link back to).
# PRIMORDIA_CANONICAL_URL=https://primordia.example.com

# Optional: URL of the parent Primordia instance to register with on startup.
# When set, this instance POSTs its identity to {PRIMORDIA_PARENT_URL}/api/instance/register
# so the parent can add it to its social graph.
# PRIMORDIA_PARENT_URL=https://primordia.exe.xyz
