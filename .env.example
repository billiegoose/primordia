# Copy this file to .env.local and fill in the values

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GitHub credentials — optional; enables authenticated git pull/push via GitSyncDialog.
# Without these, GitSyncDialog falls back to the `origin` remote (works if origin is already authenticated).
# GITHUB_TOKEN=ghp_...          # Personal access token with repo scope
# GITHUB_REPO=owner/repo        # e.g. primordia-org/primordia

# Reverse proxy port — the public-facing port users connect to.
# The Next.js app listens on PORT (default 3001); the proxy forwards there.
# REVERSE_PROXY_PORT=3000
